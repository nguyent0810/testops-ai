# -----------------------------------------------------------------------------
# Database (Neon Postgres) — used by drizzle-kit and `pnpm db:migrate`
# Use the same database as apps/web and apps/worker. For migrations, Neon’s
# direct (non-pooled) URL may be required if the pooler rejects DDL; see Neon docs.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://USER:PASSWORD@ep-XXXX.us-east-2.aws.neon.tech/neondb?sslmode=require
