# -----------------------------------------------------------------------------
# Clerk (auth) — required for sign-in and API routes
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Required for POST /api/webhooks/clerk (org/user sync). Omit only if webhooks unused.
CLERK_WEBHOOK_SIGNING_SECRET=whsec_...

# -----------------------------------------------------------------------------
# Database (Neon Postgres) — required; same logical DB as worker and migrations
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://USER:PASSWORD@ep-XXXX.aws.neon.tech/neondb?sslmode=require

# -----------------------------------------------------------------------------
# Redis (BullMQ) — required for document processing queue; same URL as worker
# -----------------------------------------------------------------------------
REDIS_URL=rediss://default:TOKEN@HOST:6379

# -----------------------------------------------------------------------------
# S3-compatible storage — required for uploads and worker ingest (GetObject)
# On Vercel, explicit keys are usually required unless you add another credential path.
# -----------------------------------------------------------------------------
AWS_REGION=us-east-1
S3_BUCKET=your-bucket-name
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
