# -----------------------------------------------------------------------------
# Redis (BullMQ) — required; same URL as web app
# -----------------------------------------------------------------------------
REDIS_URL=rediss://default:TOKEN@HOST:6379

# -----------------------------------------------------------------------------
# Database (Neon Postgres) — required; same logical DB as web app
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# -----------------------------------------------------------------------------
# S3-compatible storage — required for ingest (GetObject); same as web
# Optional credentials when the host provides IAM/instance role access to S3.
# -----------------------------------------------------------------------------
AWS_REGION=us-east-1
S3_BUCKET=your-bucket-name
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# -----------------------------------------------------------------------------
# OpenAI — required for AI jobs (requirements + test cases)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...

# Optional; defaults to gpt-4o-mini in code if unset
# OPENAI_MODEL=gpt-4o-mini
